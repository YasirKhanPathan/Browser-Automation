generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskType {
  SCRAPE
  FORM_FILL
  SCREENSHOT
  CUSTOM
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ResultStatus {
  SUCCESS
  ERROR
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  passwordHash   String
  notifyEmail    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  tasks          Task[]
  schedules      Schedule[]
  webhooks       Webhook[]
}

model Task {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        TaskType
  description String
  config      Json?
  status      TaskStatus   @default(PENDING)
  apiKey      String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  results     TaskResult[]
  screenshots Screenshot[]
  schedules   Schedule[]
  webhooks    Webhook[]
}

model TaskResult {
  id        String       @id @default(uuid())
  taskId    String
  task      Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status    ResultStatus
  data      Json?
  errorMsg  String?
  duration  Int?
  createdAt DateTime     @default(now())
}

model Screenshot {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename  String
  filepath  String
  pageUrl   String
  createdAt DateTime @default(now())
}

model Schedule {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  cronExpr    String
  enabled     Boolean  @default(true)
  lastRun     DateTime?
  nextRun     DateTime?
  notifyEmail String?
  createdAt   DateTime @default(now())
}

model Webhook {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url       String
  secret    String?
  events    String[]
  enabled   Boolean  @default(true)
  lastFired DateTime?
  createdAt DateTime @default(now())
}
