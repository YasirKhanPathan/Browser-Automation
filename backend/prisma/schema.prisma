generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskType {
  SCRAPE
  FORM_FILL
  SCREENSHOT
  CUSTOM
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ResultStatus {
  SUCCESS
  ERROR
}

model Task {
  id          String       @id @default(uuid())
  name        String
  type        TaskType
  description String
  config      Json?
  status      TaskStatus   @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  results     TaskResult[]
  screenshots Screenshot[]
}

model TaskResult {
  id        String       @id @default(uuid())
  taskId    String
  task      Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status    ResultStatus
  data      Json?
  errorMsg  String?
  duration  Int?
  createdAt DateTime     @default(now())
}

model Screenshot {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename  String
  filepath  String
  pageUrl   String
  createdAt DateTime @default(now())
}
